{
    "log": {
      "loglevel": "{{LOG_LEVEL}}",
      "dnsLog": true,
      "access": "{{LOG_DIR}}/access.log",
      "error": "{{LOG_DIR}}/error.log"
    },
    "dns": {
      "hosts": {
        "dns.google": [
          "8.8.8.8",
          "8.8.4.4"
        ],
        "cloudflare-dns.com": [
          "1.1.1.1",
          "1.0.0.1"
        ]
      },
      "servers": [
        "https+local://dns.google/dns-query",
        "https+local://cloudflare-dns.com/dns-query"
      ],
      "queryStrategy": "UseIP",
      "disableCache": false
    },
    "routing": {
        "domainStrategy": "AsIs",
        "rules": [
          {% if BLOCK_ADS %}
          {
              "type": "field",
              "domain": [
                  "geosite:category-ads-all"
              ],
              "outboundTag": "block"
          },
          {% endif %}

          {
            "type": "field",
            "domain": [
              "geosite:google",
              "geosite:microsoft",
              "geosite:apple",
              "geosite:telegram",
              "geosite:github",
              "geosite:mozilla"
            ],
            "outboundTag": "ip-audit"
          },

          {% if BLOCK_CN %}
          {
              "type": "field",
              "domain": [
                  "geosite:cn"
              ],
              "outboundTag": "block"
          },
          {% endif %}

          {
            "type": "field",
            "network": "tcp,udp",
            "outboundTag": "ip-audit"
          }
        ]
    },
    "inbounds": [
      {
        "listen": "0.0.0.0",
        "port": 8443,
        "protocol": "vless",
        "settings": {
          "clients": [
            {{ USERS }}
          ],
          "decryption": "none"
        },
        "streamSettings": {
          "network": "raw",
          "security": "reality",
          "realitySettings": {
            "show": false,
            "target": "{{ TARGET_HOST }}:{{ TARGET_PORT }}",
            "xver": 0,
            "serverNames": [
              "{{ TARGET_HOST }}"
            ],
            "privateKey": "{{ PRIVATE_KEY }}",
            "shortIds": [
              ""
            ]
          },
          "sockopt": {
              "tcpFastOpen": true
          }
        },
        "sniffing": {
          "enabled": true,
          "routeOnly": true,
          "destOverride": [
              "http",
              "tls",
              "quic"
          ]
        }
      }
    ],
    "outbounds": [
        {
          "protocol": "socks",
            "tag": "ip-audit",
            "settings": {
              "servers": [
                {
                  "address": "127.0.0.1",
                  "port": 1080
                }
              ]
            },
            "streamSettings": {
              "sockopt": {
                "domainStrategy": "UseIP"
              }
            }
        },
        {
            "protocol": "blackhole",
            "tag": "block"
        }
    ]
  }